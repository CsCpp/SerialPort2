<Window x:Class="BatterySerialMonitor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BatterySerialMonitor"
        mc:Ignorable="d"
        Title="Battery Serial Monitor (MVVM)" Height="400" Width="350"
        Background="#F5F5F5">

    <Grid Margin="20">
        <!-- Определяем строки для каждого элемента -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок Напряжение -->
            <RowDefinition Height="Auto"/>
            <!-- Значение Напряжение -->
            <RowDefinition Height="Auto"/>
            <!-- Заголовок Ток -->
            <RowDefinition Height="Auto"/>
            <!-- Значение Ток -->
            <RowDefinition Height="*"/>
            <!-- Пружина (пустое место) -->
            <RowDefinition Height="Auto"/>
            <!-- Разделитель -->
            <RowDefinition Height="Auto"/>
            <!-- Статус-бар -->
        </Grid.RowDefinitions>

        <!-- Секция Напряжения -->
        <TextBlock Grid.Row="0" Text="НАПРЯЖЕНИЕ (V)" 
                   FontSize="12" FontWeight="SemiBold" Foreground="#666666"/>

        <TextBlock Grid.Row="1" Text="{Binding CurrentData.Voltage, StringFormat={}{0:F2}}" 
                   FontSize="54" FontWeight="Bold" Foreground="#2E7D32" 
                   HorizontalAlignment="Left" Margin="0,0,0,20"/>

        <!-- Секция Тока -->
        <TextBlock Grid.Row="2" Text="ТОК (A)" 
                   FontSize="12" FontWeight="SemiBold" Foreground="#666666"/>

        <TextBlock Grid.Row="3" Text="{Binding CurrentData.Current, StringFormat={}{0:F2}}" 
                   FontSize="54" FontWeight="Bold" Foreground="#1565C0" 
                   HorizontalAlignment="Left"/>

        <!-- Нижняя часть со статусом -->
        <Separator Grid.Row="5" Margin="0,10" Background="#DDDDDD"/>

        <TextBlock Grid.Row="6" Text="{Binding StatusMessage}" 
                   FontSize="11" FontStyle="Italic" Foreground="#C62828"
                   TextWrapping="Wrap"/>
    </Grid>
</Window>