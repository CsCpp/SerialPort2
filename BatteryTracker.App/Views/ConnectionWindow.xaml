<Window  x:Class="BatteryTracker.App.Views.ConnectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BatteryTracker.App.Views"
        mc:Ignorable="d"
          Title="Настройка подключения" Height="250" Width="300"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Выберите порт:"/>
            <ComboBox ItemsSource="{Binding AvailablePorts}" 
                      SelectedItem="{Binding SelectedPort}" Margin="0,5,0,15"/>

            <TextBlock Text="Скорость (Baud):"/>
            <ComboBox ItemsSource="{Binding BaudRates}" 
                      SelectedItem="{Binding SelectedBaudRate}" Margin="0,5,0,20"/>

            <Button Content="ПОДКЛЮЧИТЬСЯ" Height="35" 
                    Click="Connect_Click"
                    Background="LightBlue" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
