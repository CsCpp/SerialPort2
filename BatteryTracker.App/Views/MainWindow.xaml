<Window x:Class="BatteryTracker.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:live="clr-namespace:LiveChartsCore;assembly=LiveChartsCore" 
        xmlns:viewmodels="clr-namespace:BatteryTracker.App.ViewModels" 
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
        Title="BatteryTracker v1.0" Height="600" Width="1100"
        Background="#F5F5F5">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. Панель управления -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="📁 Открыть лог-файл" Click="OpenFile_Click" Padding="15,5" Cursor="Hand"/>
            <TextBlock Text="Масштабирование: Колесо мыши (Zoom), Правая кнопка (Pan)" 
                       VerticalAlignment="Center" Margin="20,0" Foreground="#888888" FontSize="11"/>
        </StackPanel>

        <!-- 2. Основная рабочая область -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ЛЕВАЯ ПАНЕЛЬ -->
            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                <TextBlock Text="НАПРЯЖЕНИЕ (V)" FontSize="12" FontWeight="SemiBold" Foreground="#666666"/>
                <TextBlock Text="{Binding CurrentData.Voltage, StringFormat={}{0:F2}}" 
                           FontSize="54" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,0,20"/>

                <TextBlock Text="ТОК (A)" FontSize="12" FontWeight="SemiBold" Foreground="#666666"/>
                <TextBlock Text="{Binding CurrentData.Current, StringFormat={}{0:F2}}" 
                           FontSize="54" FontWeight="Bold" Foreground="#1565C0" Margin="0,0,0,20"/>

                <TextBlock Text="ТЕМПЕРАТУРА (°C)" FontSize="12" FontWeight="SemiBold" Foreground="#666666"/>
                <TextBlock Text="{Binding CurrentData.Temperature, StringFormat={}{0:F1}}" 
                           FontSize="32" FontWeight="Bold" Foreground="#EF6C00"/>
            </StackPanel>

            <!-- ПРАВАЯ ПАНЕЛЬ (График) -->
            <Border Grid.Column="1" Background="White" CornerRadius="5" Padding="10">
                <!-- Исправлено: ZoomMode="X" и правильная привязка CombinedSeries -->
                <lvc:CartesianChart Series="{Binding CombinedSeries}"
                                    ZoomMode="X" 
                                    LegendPosition="Top">
                    <lvc:CartesianChart.XAxes>
                        <lvc:Axis Labeler="{Binding XFormatter}" />
                    </lvc:CartesianChart.XAxes>
                    <lvc:CartesianChart.YAxes>
                        <!-- Ось 0: Напряжение -->
                        <lvc:Axis Name="Вольты (V)" Position="Start" />
                        <!-- Ось 1: Ток -->
                        <lvc:Axis Name="Амперы (A)" Position="End" ShowSeparatorLines="False" />
                    </lvc:CartesianChart.YAxes>
                </lvc:CartesianChart>
            </Border>
        </Grid>

        <!-- 3. Статус-бар -->
        <StatusBar Grid.Row="2" Background="Transparent" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="11" FontStyle="Italic" Foreground="#666666"/>
        </StatusBar>
    </Grid>
</Window>