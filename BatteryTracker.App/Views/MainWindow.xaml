<Window x:Class="BatteryTracker.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vmodels="clr-namespace:BatteryTracker.App.ViewModels"
        Title="BatteryTracker v1.0" Height="600" Width="1100">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="📁 Открыть лог" Click="OpenFile_Click" Padding="10,5"/>
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="20,0"/>
        </StackPanel>

        <!-- Пустой контейнер с именем ChartHost -->
        <Border x:Name="ChartHost" Grid.Row="1" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" />
    </Grid>
</Window>